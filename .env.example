# Copy this file to .env and fill in values that differ from your machine's
# Postgres defaults. .env is gitignored; .env.example is the template.
#
# Not needed at all if your local Postgres trusts your OS user (peer/local
# auth) — that's the default assumption in config/database.yml. If your
# Postgres instead requires a username/password (common with Docker,
# Homebrew, or the Windows installer), set DB_USERNAME below — that's what
# switches config/database.yml from the OS-trust connection to these
# explicit credentials. DB_HOST/DB_PORT default to localhost/5432 if unset.
#
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432
